                            <ui:VisualElement class="summary-card glance-card">
                                <ui:Label text="Channel filter" class="eyebrow" />
                                <ui:Label name="social-channel-value" text="ALL filter active." class="summary-value summary-value--glance" />
                            </ui:VisualElement>
                            <ui:VisualElement class="summary-card glance-card">
                                <ui:Label text="Traffic" class="eyebrow" />
                                <ui:Label name="social-traffic-value" text="No visible lines." class="summary-value summary-value--glance" />
                            </ui:VisualElement>
                            <ui:VisualElement class="summary-card glance-card">
                                <ui:Label text="Connection posture" class="eyebrow" />
                                <ui:Label name="social-connection-value" text="No connection posture yet." class="summary-value summary-value--glance" />
                            </ui:VisualElement>
                            <ui:VisualElement class="summary-card glance-card">
                                <ui:Label text="System notice" class="eyebrow" />
                                <ui:Label name="social-system-value" text="No system notice yet." class="summary-value summary-value--glance" />
                            </ui:VisualElement>
                            <ui:VisualElement class="summary-card glance-card">
                                <ui:Label text="Desk note" class="eyebrow" />
                                <ui:Label name="social-note-value" text="Read-only social desk keeps room/filter truth visible without inventing a full social stack." class="summary-value summary-value--glance" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:ScrollView>
</ui:VisualElement>

            <ui:VisualElement name="bottom-comms" class="panel comms-panel">
                <ui:VisualElement class="comms-header-row">
                    <ui:VisualElement>
                        <ui:Label text="Comms" class="eyebrow" />
                        <ui:Label name="comms-status-value" text="No chat yet." class="comms-value" />
                    </ui:VisualElement>
                    <ui:VisualElement class="button-row button-row--tight chat-chip-row">
                        <ui:Button name="chat-all-button" text="All" class="action-button chat-chip action-button--primary" />
                        <ui:Button name="chat-room-button" text="Room" class="action-button chat-chip" />
                        <ui:Button name="chat-system-button" text="System" class="action-button chat-chip" />
                    </ui:VisualElement>
                </ui:VisualElement>

                <ui:ScrollView name="chat-log-scroll" class="chat-log-scroll" mode="Vertical" />

                <ui:VisualElement class="chat-compose-row">
                    <ui:TextField name="chat-input-field" class="chat-input-field" label="Say" />
                    <ui:Button name="send-chat-button" text="Send" class="action-button action-button--primary chat-send-button" />
                </ui:VisualElement>

                <ui:Label name="comms-hint-value" text="This band now shows recent lines, simple filters, and a basic send box." class="comms-copy" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
