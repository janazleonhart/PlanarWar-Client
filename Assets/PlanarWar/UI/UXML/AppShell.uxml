                                    <ui:Label name="heroes-card-2-lore-value" text="Hero truth appears here." class="summary-value summary-value--glance" />
                                    <ui:Label name="heroes-card-2-note-value" text="Hero desk." class="metric-subvalue metric-subvalue--wrap" />
                                    <ui:Button name="heroes-card-2-button" text="Hero action" class="action-button action-button--primary" />
                                </ui:VisualElement>
                                <ui:VisualElement name="heroes-card-3-root" class="summary-card glance-card heroes-roster-card">
                                    <ui:Label name="heroes-card-3-family-value" text="Roster" class="eyebrow" />
                                    <ui:Label name="heroes-card-3-title-value" text="Hero card" class="rail-note-title" />
                                    <ui:Label name="heroes-card-3-lore-value" text="Hero truth appears here." class="summary-value summary-value--glance" />
                                    <ui:Label name="heroes-card-3-note-value" text="Hero desk." class="metric-subvalue metric-subvalue--wrap" />
                                    <ui:Button name="heroes-card-3-button" text="Hero action" class="action-button action-button--primary" />
                                </ui:VisualElement>
                                <ui:VisualElement name="heroes-card-4-root" class="summary-card glance-card heroes-roster-card">
                                    <ui:Label name="heroes-card-4-family-value" text="Roster" class="eyebrow" />
                                    <ui:Label name="heroes-card-4-title-value" text="Hero card" class="rail-note-title" />
                                    <ui:Label name="heroes-card-4-lore-value" text="Hero truth appears here." class="summary-value summary-value--glance" />
                                    <ui:Label name="heroes-card-4-note-value" text="Hero desk." class="metric-subvalue metric-subvalue--wrap" />
                                    <ui:Button name="heroes-card-4-button" text="Hero action" class="action-button action-button--primary" />
                                </ui:VisualElement>
                            </ui:VisualElement>
                        </ui:VisualElement>

                    </ui:VisualElement>
                </ui:ScrollView>

                <ui:ScrollView name="social-screen" class="screen-panel screen-scroll" mode="Vertical">
                    <ui:VisualElement class="screen-scroll-content social-screen-content">
                        <ui:VisualElement class="summary-hero">
                            <ui:Label text="Shared comms" class="eyebrow" />
                            <ui:Label name="social-headline-value" text="Social desk" class="headline" />
                            <ui:Label name="social-copy-value" text="Read-only room state, filter posture, and recent lines render here." class="headline-subtext" />
                        </ui:VisualElement>

                        <ui:VisualElement class="summary-card summary-card--full">
                            <ui:Label text="Comms overview" class="eyebrow" />
                            <ui:Label name="social-overview-value" text="Room and filter posture load here." class="summary-value summary-value--glance" />
                        </ui:VisualElement>

                        <ui:VisualElement class="summary-card summary-card--full">
                            <ui:Label text="Visible social cards" class="eyebrow" />
                            <ui:VisualElement class="summary-grid summary-grid--desk-cards">
                                <ui:VisualElement name="social-card-1-root" class="summary-card glance-card">
                                    <ui:Label name="social-card-1-title" text="Room state" class="eyebrow" />
                                    <ui:Label name="social-card-1-title-value" text="No room state" class="rail-note-title" />
                                    <ui:Label name="social-card-1-lore-value" text="Room truth will appear here." class="summary-value summary-value--glance" />
                                    <ui:Label name="social-card-1-note-value" text="Read-only social desk." class="metric-subvalue metric-subvalue--wrap" />
                                </ui:VisualElement>
                                <ui:VisualElement name="social-card-2-root" class="summary-card glance-card">
                                    <ui:Label name="social-card-2-title" text="Channel filter" class="eyebrow" />
                                    <ui:Label name="social-card-2-title-value" text="No filter state" class="rail-note-title" />
                                    <ui:Label name="social-card-2-lore-value" text="Filter truth will appear here." class="summary-value summary-value--glance" />
                                    <ui:Label name="social-card-2-note-value" text="Read-only social desk." class="metric-subvalue metric-subvalue--wrap" />
                                </ui:VisualElement>
                                <ui:VisualElement name="social-card-3-root" class="summary-card glance-card">
                                    <ui:Label name="social-card-3-title" text="Recent line" class="eyebrow" />
                                    <ui:Label name="social-card-3-title-value" text="No entry" class="rail-note-title" />
                                    <ui:Label name="social-card-3-lore-value" text="Recent comms truth will appear here." class="summary-value summary-value--glance" />
                                    <ui:Label name="social-card-3-note-value" text="Read-only social desk." class="metric-subvalue metric-subvalue--wrap" />
                                </ui:VisualElement>
                                <ui:VisualElement name="social-card-4-root" class="summary-card glance-card">
                                    <ui:Label name="social-card-4-title" text="Secondary line" class="eyebrow" />
                                    <ui:Label name="social-card-4-title-value" text="No entry" class="rail-note-title" />
                                    <ui:Label name="social-card-4-lore-value" text="Secondary comms truth will appear here." class="summary-value summary-value--glance" />
                                    <ui:Label name="social-card-4-note-value" text="Read-only social desk." class="metric-subvalue metric-subvalue--wrap" />
                                </ui:VisualElement>
                            </ui:VisualElement>
                        </ui:VisualElement>

                        <ui:VisualElement class="summary-grid summary-grid--desk-support">
                            <ui:VisualElement class="summary-card glance-card">
                                <ui:Label text="Room state" class="eyebrow" />
                                <ui:Label name="social-room-value" text="No room attached yet." class="summary-value summary-value--glance" />
