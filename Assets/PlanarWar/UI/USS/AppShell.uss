}

.operations-native-picker-hidden {
    display: none;
}

.operations-choice-list {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 6px;
    min-height: 32px;
    align-items: flex-start;
}

.operations-choice-list--cells .operations-choice {
    min-width: 210px;
}

.operations-choice-list--posture .operations-choice {
    min-width: 120px;
}

.operations-choice {
    min-width: 150px;
