/* Operations / Dispatch inline picker cleanup v1 */
.operations-management-card {
    gap: 10px;
}

.operations-management-head {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.operations-management-title-stack {
    flex-grow: 1;
    gap: 2px;
}

.operations-pill {
    flex-shrink: 0;
    padding-left: 10px;
    padding-right: 10px;
    padding-top: 3px;
    padding-bottom: 3px;
    background-color: rgba(46, 72, 139, 0.78);
    color: rgb(225, 234, 255);
    border-top-left-radius: 999px;
    border-top-right-radius: 999px;
    border-bottom-left-radius: 999px;
    border-bottom-right-radius: 999px;
    font-size: 10px;
