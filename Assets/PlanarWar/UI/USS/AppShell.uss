}

.operations-management-section {
    flex-grow: 1;
    min-width: 300px;
    gap: 7px;
    padding-left: 10px;
    padding-right: 10px;
    padding-top: 9px;
    padding-bottom: 9px;
    background-color: rgba(10, 19, 43, 0.72);
