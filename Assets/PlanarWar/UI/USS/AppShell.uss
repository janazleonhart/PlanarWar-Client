    border-right-color: rgb(143, 170, 255);
    border-top-color: rgb(143, 170, 255);
    border-bottom-color: rgb(143, 170, 255);
    -unity-font-style: bold;
}

.heroes-armory-choice-empty {
    min-height: 32px;
    padding-left: 10px;
    padding-right: 10px;
    padding-top: 8px;
    padding-bottom: 8px;
    background-color: rgba(8, 14, 30, 0.72);
    color: rgb(165, 178, 214);
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
    font-size: 11px;
    white-space: normal;
}

/* Hero / Operative recruitment candidate inline picker v1 */
