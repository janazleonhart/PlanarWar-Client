/* Operations / Dispatch cursed-layout fix v1a */
.operations-management-card {
    flex-shrink: 0;
    gap: 8px;
}

.operations-management-head {
    flex-shrink: 0;
    min-height: 34px;
    margin-bottom: 2px;
}

.operations-management-title-stack .rail-note-title {
    white-space: normal;
    font-size: 12px;
}

.operations-management-card > .metric-subvalue {
    flex-shrink: 0;
}

.operations-management-grid {
    flex-direction: column;
    flex-wrap: nowrap;
    gap: 8px;
    align-items: stretch;
}

.operations-management-section {
    flex-shrink: 0;
    min-width: 0;
    gap: 6px;
    padding-top: 8px;
    padding-bottom: 8px;
}

.operations-choice-list {
    flex-shrink: 0;
    min-height: 28px;
    gap: 5px;
}

.operations-choice-list--cells .operations-choice,
.operations-choice {
    min-height: 26px;
    padding-left: 9px;
    padding-right: 9px;
    padding-top: 5px;
    padding-bottom: 5px;
    font-size: 10px;
}

.operations-inline-form {
    flex-shrink: 0;
}

.operations-management-note {
    flex-shrink: 0;
    max-height: 116px;
    overflow: hidden;
    white-space: normal;
}


/* Operations / Dispatch overview density cleanup v1b */
.operations-overview-card--compact {
    gap: 4px;
    padding-top: 10px;
    padding-bottom: 10px;
}

.operations-overview-card--compact .summary-value {
    white-space: normal;
    font-size: 11px;
}

.operations-action-board {
    gap: 8px;
}

.operations-action-board > .metric-subvalue {
    max-height: 28px;
    overflow: hidden;
}

.operations-action-board .warfront-cards-grid {
    gap: 10px;
    margin-top: 0;
}

.operations-action-board .warfront-desk-card {
    min-height: 136px;
    gap: 6px;
    padding-top: 12px;
    padding-bottom: 12px;
}

.operations-action-board .warfront-desk-card .summary-value {
    max-height: 34px;
    overflow: hidden;
}

.operations-action-board .warfront-desk-card .metric-subvalue {
    display: none;
}

.operations-support-grid--hidden {
    display: none;
}


/* Development surface cleanup v1 */
.development-action-board {
    gap: 8px;
    flex-shrink: 0;
}

.development-action-board .development-actions-head {
    gap: 3px;
}

.development-action-board .development-actions-head .metric-subvalue {
    max-height: 28px;
    overflow: hidden;
}

.development-action-board .development-research-cards-grid,
.development-action-board .development-info-cards-grid {
    gap: 10px;
    margin-top: 0;
}

.development-action-board .development-research-card,
.development-action-board .development-info-card {
    min-width: 230px;
    min-height: 136px;
    gap: 6px;
    padding-top: 12px;
    padding-bottom: 12px;
}

.development-action-board .development-research-card .summary-value,
.development-action-board .development-info-card .summary-value {
    max-height: 34px;
    overflow: hidden;
}

.development-action-board .development-research-card .metric-subvalue,
.development-action-board .development-info-card .metric-subvalue {
    display: none;
}

.development-action-board .development-research-card .action-button,
.development-action-board .development-info-card .action-button {
    min-width: 132px;
    align-self: stretch;
    margin-top: auto;
}

.development-support-grid--hidden {
    display: none;
}

.development-desk-actions-card {
    gap: 8px;
    padding-top: 10px;
    padding-bottom: 10px;
}

.development-desk-actions-card .button-row {
    margin-top: 0;
}

/* Development building selector inline picker v1a */
.development-inline-selector {
    gap: 5px;
    margin-top: 6px;
    flex-shrink: 0;
}

.development-inline-selector-label {
    color: rgb(139, 158, 210);
    font-size: 10px;
    -unity-font-style: bold;
}

.development-inline-selector-options {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 5px;
    align-items: flex-start;
}

.development-inline-selector-choice {
    min-height: 26px;
    min-width: 150px;
    padding-left: 9px;
    padding-right: 9px;
    padding-top: 5px;
    padding-bottom: 5px;
    background-color: rgba(22, 36, 73, 0.95);
    color: rgb(210, 222, 255);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(95, 126, 210, 0.44);
    border-right-color: rgba(95, 126, 210, 0.44);
    border-top-color: rgba(95, 126, 210, 0.44);
    border-bottom-color: rgba(95, 126, 210, 0.44);
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
    font-size: 10px;
    white-space: normal;
    -unity-text-align: middle-left;
}

.development-inline-selector-choice:hover {
    background-color: rgba(46, 72, 139, 0.98);
    color: rgb(242, 246, 255);
}

.development-inline-selector-choice--selected {
    background-color: rgb(62, 96, 187);
    color: rgb(255, 255, 255);
    border-left-color: rgb(143, 170, 255);
    border-right-color: rgb(143, 170, 255);
    border-top-color: rgb(143, 170, 255);
    border-bottom-color: rgb(143, 170, 255);
    -unity-font-style: bold;
}


/* Home command surface cleanup v1 */
.home-command-hero {
    gap: 5px;
    padding-bottom: 6px;
}

.home-resource-strip {
    padding-top: 10px;
    padding-bottom: 10px;
}

.home-resource-strip .ticker-value {
    font-size: 16px;
    line-height: 1.25;
}

.home-quick-orders {
    padding-top: 10px;
    padding-bottom: 10px;
}

.home-quick-orders .button-row {
    gap: 8px;
    flex-wrap: wrap;
}

.home-quick-orders .action-button {
    min-width: 126px;
    min-height: 30px;
}

.home-pressure-desk {
    gap: 8px;
    padding-top: 12px;
    padding-bottom: 12px;
}

.home-pressure-desk > .rail-note-title {
    white-space: normal;
}

.home-pressure-desk > .summary-value {
    max-height: 42px;
    overflow: hidden;
}

.home-pressure-grid--hidden {
    display: none;
}

.home-fast-option-strip {
    margin-top: 4px;
    gap: 10px;
}

.home-fast-option-strip .pressure-op-card {
    min-height: 132px;
    gap: 6px;
    padding-top: 10px;
    padding-bottom: 10px;
}

.pressure-op-card--compact .rail-note-title {
    white-space: normal;
}

.pressure-op-card__summary {
    max-height: 36px;
    overflow: hidden;
}

.pressure-op-card__signal {
    max-height: 34px;
    overflow: hidden;
}

.home-timer-strip {
    gap: 8px;
    margin-top: 8px;
    margin-bottom: 8px;
}

.home-timer-strip .timer-card {
    min-height: 72px;
    padding-top: 10px;
    padding-bottom: 10px;
}

.home-status-grid {
    gap: 8px;
}

.home-status-grid .glance-card {
    min-height: 84px;
    padding-top: 10px;
    padding-bottom: 10px;
}


/* Home dev diagnostic gate v1a */
.home-dev-diagnostic-gated {
    display: none;
}


/* Chapter rail status polish v1 */
.chapter-row__badge {
    margin-left: 6px;
    padding-left: 6px;
    padding-right: 6px;
    padding-top: 2px;
    padding-bottom: 2px;
    background-color: rgba(24, 40, 86, 0.82);
    border-top-left-radius: 999px;
    border-top-right-radius: 999px;
    border-bottom-left-radius: 999px;
    border-bottom-right-radius: 999px;
}

.chapter-row__action {
    flex-shrink: 0;
    margin-left: 8px;
    padding-left: 7px;
    padding-right: 7px;
    padding-top: 3px;
    padding-bottom: 3px;
    background-color: rgba(8, 14, 30, 0.66);
    border-top-left-radius: 999px;
    border-top-right-radius: 999px;
    border-bottom-left-radius: 999px;
    border-bottom-right-radius: 999px;
    -unity-text-align: middle-center;
}

.rail-panel--compact .chapter-row__badge {
    margin-left: 5px;
    padding-left: 5px;
    padding-right: 5px;
}

.rail-panel--compact .chapter-row__action {
    min-width: 44px;
    margin-left: 6px;
    padding-left: 6px;
    padding-right: 6px;
}


/* Social / Comms surface cleanup v1 */
.social-surface-content {
    gap: 12px;
}

.social-command-hero {
    gap: 6px;
    padding-top: 8px;
    padding-bottom: 10px;
}

.social-command-hero .headline {
    font-size: 24px;
}

.social-command-hero .headline-subtext {
    font-size: 13px;
    white-space: normal;
}

.social-overview-strip {
    gap: 4px;
    padding-top: 10px;
    padding-bottom: 10px;
}

.social-overview-strip .summary-value {
    font-size: 12px;
    white-space: normal;
}

.social-comms-board {
    gap: 8px;
}

.social-comms-card-grid {
    gap: 10px;
    align-items: stretch;
}

.social-comms-card {
    min-height: 126px;
    gap: 6px;
    padding-top: 12px;
    padding-bottom: 12px;
}

.social-comms-card .summary-value {
    max-height: 40px;
    overflow: hidden;
}

.social-comms-card .metric-subvalue {
    max-height: 28px;
    overflow: hidden;
    font-size: 11px;
}

.social-support-grid--hidden {
    display: none;
}

.comms-panel {
    min-height: 196px;
}

.chat-log-scroll {
    min-height: 96px;
    max-height: 132px;
}

.comms-copy {
    font-size: 11px;
}

/* Operations mission board / dispatch clarity v1 */
.operations-mission-board {
    flex-shrink: 0;
    gap: 8px;
}

.operations-mission-board-grid {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 8px;
    align-items: stretch;
}

.operations-mission-board-section {
    min-width: 360px;
    flex-grow: 1;
}

.operations-mission-offer-picker .operations-choice {
    min-width: 220px;
}



.post-founder-handoff-card {
    gap: 10px;
    display: none;
}

.post-founder-handoff-actions {
    margin-top: 4px;
}

.founder-setup-card {
    gap: 10px;
}

.founder-name-field {
    max-width: 520px;
    margin-top: 4px;
}

.founder-name-field .unity-base-field__label {
    min-width: 120px;
    color: rgb(145, 165, 220);
    -unity-font-style: bold;
}

.founder-primary-actions {
    margin-top: 4px;
}

.founder-choice-grid {
    margin-top: 6px;
    gap: 12px;
}

.founder-choice-card {
    min-width: 280px;
    min-height: 188px;
    gap: 8px;
}

.founder-choice-card .action-button {
    margin-top: auto;
}


.founder-action-status {
    margin-top: 4px;
    padding: 8px 10px;
    border-radius: 8px;
    background-color: rgba(72, 101, 186, 0.18);
    border-left-width: 3px;
    border-left-color: rgba(124, 154, 255, 0.9);
}

.founder-action-status--error {
    background-color: rgba(172, 67, 67, 0.18);
    border-left-color: rgba(255, 128, 128, 0.95);
}

.workshop-recipe-picker {
    margin-top: 8px;
    margin-bottom: 8px;
}

.workshop-recipe-picker__fields {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 6px;
    margin-bottom: 6px;
}

.workshop-recipe-picker__dropdown {
    min-width: 240px;
    flex-grow: 1;
}
